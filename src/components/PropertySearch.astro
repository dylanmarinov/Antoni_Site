---
// ─────────────────────────────────────────────────────────────
// PROPERTY SEARCH — Powered by SimplyRETS API
//
// HOW TO CONNECT REAL MLS DATA:
// 1. Go to https://simplyrets.com and create an account
// 2. Ask your broker at Charles Rutenberg Realty to authorize
//    SimplyRETS access to the MFRMLS feed (this is a standard request)
// 3. SimplyRETS will give you an API Key and Secret
// 4. Replace the DEMO credentials below with your real ones:
//    const API_USER = "your-api-key";
//    const API_PASS = "your-api-secret";
//
// Until then, the search uses SimplyRETS demo listings so the
// full search experience is live and functional.
// ─────────────────────────────────────────────────────────────
---

<section id="search">
  <div class="search-header">
    <div class="container">
      <p class="section-label">Property Search</p>
      <h2 class="section-title reveal" style="color:var(--white)">Find Your Perfect Home</h2>
      <p class="reveal" style="color:rgba(255,255,255,0.72); font-size:1rem; margin-bottom:0">
        Search available properties across the greater Tampa Bay Area — all without leaving this page.
      </p>
    </div>
  </div>

  <div class="search-body container">
    <!-- ── Filter Bar ── -->
    <div class="filter-bar reveal">
      <div class="filter-main">
        <div class="filter-group filter-location">
          <label for="f-location">Location</label>
          <input
            type="text"
            id="f-location"
            placeholder="City, address, or ZIP..."
          />
        </div>

        <div class="filter-group">
          <label for="f-status">Status</label>
          <div class="toggle-group">
            <button class="toggle-btn active" data-status="Active">Active</button>
            <button class="toggle-btn" data-status="Closed">Sold</button>
          </div>
        </div>

        <div class="filter-group">
          <label for="f-type">Type</label>
          <select id="f-type">
            <option value="">Any</option>
            <option value="Residential">Residential</option>
            <option value="Condominium">Condo</option>
            <option value="Rental">Rental</option>
            <option value="Land">Land</option>
            <option value="Commercial">Commercial</option>
          </select>
        </div>

        <div class="filter-group">
          <label>Price Range</label>
          <div class="input-pair">
            <input type="number" id="f-minprice" placeholder="Min $" min="0" step="10000" />
            <span>–</span>
            <input type="number" id="f-maxprice" placeholder="Max $" min="0" step="10000" />
          </div>
        </div>

        <div class="filter-group">
          <label for="f-beds">Beds</label>
          <select id="f-beds">
            <option value="">Any</option>
            <option value="1">1+</option>
            <option value="2">2+</option>
            <option value="3">3+</option>
            <option value="4">4+</option>
            <option value="5">5+</option>
          </select>
        </div>

        <div class="filter-group">
          <label for="f-baths">Baths</label>
          <select id="f-baths">
            <option value="">Any</option>
            <option value="1">1+</option>
            <option value="2">2+</option>
            <option value="3">3+</option>
          </select>
        </div>

        <button id="search-btn" class="btn btn-primary search-go">
          Search
        </button>
      </div>
    </div>

    <!-- ── Results area ── -->
    <div class="results-meta" id="results-meta" style="display:none">
      <span id="results-count"></span>
      <div class="sort-wrap">
        <label for="f-sort">Sort by:</label>
        <select id="f-sort">
          <option value="listdate">Newest</option>
          <option value="price">Price ↑</option>
          <option value="priceDesc">Price ↓</option>
          <option value="beds">Beds</option>
        </select>
      </div>
    </div>

    <div id="results-grid" class="results-grid"></div>

    <div id="results-loading" class="loading-grid">
      {Array(6).fill(null).map(() => (
        <div class="skeleton-card">
          <div class="skeleton-img"></div>
          <div class="skeleton-body">
            <div class="skeleton-line w60"></div>
            <div class="skeleton-line w80"></div>
            <div class="skeleton-line w40"></div>
          </div>
        </div>
      ))}
    </div>

    <div id="results-empty" class="results-empty" style="display:none">
      <div class="empty-icon">🏠</div>
      <h3>No properties found</h3>
      <p>Try adjusting your filters or broadening your search area.</p>
      <button id="reset-btn" class="btn btn-navy">Reset Filters</button>
    </div>

    <div id="results-error" class="results-error" style="display:none">
      <div class="error-icon">⚠️</div>
      <h3>Couldn't load listings</h3>
      <p>Please check your connection and try again.</p>
      <button id="retry-btn" class="btn btn-navy">Retry</button>
    </div>

    <!-- ── Pagination ── -->
    <div id="pagination" class="pagination" style="display:none">
      <button id="prev-page" class="page-btn" disabled>← Previous</button>
      <span id="page-info"></span>
      <button id="next-page" class="page-btn">Next →</button>
    </div>
  </div>
</section>

<!-- ── Property Detail Modal ── -->
<div id="prop-modal" class="modal" style="display:none" role="dialog" aria-modal="true">
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-panel">
    <button class="modal-close" id="modal-close" aria-label="Close">✕</button>
    <div id="modal-content"></div>
  </div>
</div>

<style>
  /* ── Section shell ── */
  #search {
    padding: 0;
    background: var(--gray-light);
  }

  .search-header {
    background: var(--navy);
    padding: 80px 24px 48px;
    position: relative;
    overflow: hidden;
  }

  .search-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(201,168,76,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .search-header .container { position: relative; z-index: 1; }

  .search-body {
    padding: 0 24px 80px;
  }

  /* ── Filter bar ── */
  .filter-bar {
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    padding: 28px 32px;
    margin-top: -28px;
    margin-bottom: 36px;
    position: relative;
    z-index: 2;
  }

  .filter-main {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: flex-end;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 120px;
  }

  .filter-location { flex: 1; min-width: 200px; }

  .filter-group label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--navy);
  }

  .filter-group input,
  .filter-group select {
    padding: 10px 14px;
    border: 1.5px solid #DDD;
    border-radius: 8px;
    font-size: 0.88rem;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    height: 42px;
  }

  .filter-group input:focus,
  .filter-group select:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.18);
  }

  .input-pair {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .input-pair input { width: 90px; min-width: unset; }
  .input-pair span { color: var(--gray); font-size: 0.9rem; }

  .toggle-group {
    display: flex;
    height: 42px;
    border: 1.5px solid #DDD;
    border-radius: 8px;
    overflow: hidden;
  }

  .toggle-btn {
    flex: 1;
    padding: 0 16px;
    background: transparent;
    border: none;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--gray);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .toggle-btn.active {
    background: var(--navy);
    color: var(--white);
    font-weight: 600;
  }

  .search-go {
    height: 42px;
    padding: 0 28px;
    white-space: nowrap;
    align-self: flex-end;
  }

  /* ── Results meta ── */
  .results-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }

  #results-count {
    font-size: 0.92rem;
    color: var(--gray);
    font-weight: 500;
  }

  .sort-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--gray);
  }

  .sort-wrap select {
    padding: 6px 10px;
    border: 1px solid #DDD;
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    background: var(--white);
    cursor: pointer;
    outline: none;
  }

  /* ── Results grid ── */
  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* Property card */
  .prop-card {
    background: var(--white);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
    cursor: pointer;
    transition: transform var(--transition), box-shadow var(--transition);
    display: flex;
    flex-direction: column;
  }

  .prop-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  .prop-img {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #E8E5E0;
  }

  .prop-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .prop-card:hover .prop-img img { transform: scale(1.05); }

  .prop-img-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: #CCC;
    background: #F0EDE8;
  }

  .prop-status-badge {
    position: absolute;
    top: 12px; left: 12px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 50px;
    background: var(--gold);
    color: var(--navy-dark);
  }

  .prop-status-badge.sold {
    background: var(--navy);
    color: var(--white);
  }

  .prop-dom {
    position: absolute;
    top: 12px; right: 12px;
    font-size: 0.68rem;
    font-weight: 600;
    background: rgba(0,0,0,0.55);
    color: white;
    padding: 3px 8px;
    border-radius: 50px;
  }

  .prop-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .prop-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--navy);
  }

  .prop-address {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .prop-city {
    font-size: 0.8rem;
    color: var(--gray);
    margin-bottom: 8px;
  }

  .prop-details {
    display: flex;
    gap: 14px;
    font-size: 0.82rem;
    color: #666;
    padding-top: 10px;
    border-top: 1px solid var(--gray-light);
    flex-wrap: wrap;
  }

  .prop-details span { display: flex; align-items: center; gap: 4px; }
  .prop-details strong { color: var(--text); }

  .prop-type {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray);
    margin-top: 8px;
  }

  /* ── Skeleton loader ── */
  .loading-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .skeleton-card {
    background: var(--white);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .skeleton-img {
    aspect-ratio: 4/3;
    background: linear-gradient(90deg, #f0ede8 25%, #e5e0d8 50%, #f0ede8 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  .skeleton-body { padding: 18px 20px; display: flex; flex-direction: column; gap: 10px; }

  .skeleton-line {
    height: 14px;
    border-radius: 6px;
    background: linear-gradient(90deg, #f0ede8 25%, #e5e0d8 50%, #f0ede8 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  .skeleton-line.w60 { width: 60%; }
  .skeleton-line.w80 { width: 80%; }
  .skeleton-line.w40 { width: 40%; }

  @keyframes shimmer {
    from { background-position: 200% 0; }
    to   { background-position: -200% 0; }
  }

  /* ── Empty / Error states ── */
  .results-empty,
  .results-error {
    text-align: center;
    padding: 80px 24px;
    background: var(--white);
    border-radius: 16px;
  }

  .empty-icon,
  .error-icon {
    font-size: 3rem;
    margin-bottom: 16px;
  }

  .results-empty h3,
  .results-error h3 {
    font-size: 1.4rem;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .results-empty p,
  .results-error p {
    color: var(--gray);
    margin-bottom: 24px;
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 40px;
  }

  .page-btn {
    padding: 10px 24px;
    border: 1.5px solid var(--navy);
    border-radius: 50px;
    background: transparent;
    color: var(--navy);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s, color 0.2s;
  }

  .page-btn:hover:not(:disabled) { background: var(--navy); color: var(--white); }
  .page-btn:disabled { opacity: 0.35; cursor: not-allowed; }

  #page-info {
    font-size: 0.88rem;
    color: var(--gray);
    font-weight: 500;
  }

  /* ── Modal ── */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(18,40,73,0.7);
    backdrop-filter: blur(6px);
  }

  .modal-panel {
    position: relative;
    background: var(--white);
    border-radius: 20px;
    width: 100%;
    max-width: 820px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 80px rgba(0,0,0,0.3);
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp {
    from { transform: translateY(30px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .modal-close {
    position: sticky;
    top: 16px;
    float: right;
    margin: 16px 16px 0 0;
    width: 36px; height: 36px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,0.08);
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 1;
  }

  .modal-close:hover { background: rgba(0,0,0,0.15); }

  /* Modal content styles */
  .modal-imgs {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: 20px 20px 0 0;
    background: #eee;
  }

  .modal-imgs img {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .modal-body { padding: 28px 32px 36px; }

  .modal-price {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 4px;
  }

  .modal-address {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 20px;
  }

  .modal-stats {
    display: flex;
    gap: 32px;
    padding: 20px 0;
    border-top: 1px solid var(--gray-light);
    border-bottom: 1px solid var(--gray-light);
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .modal-stat { display: flex; flex-direction: column; gap: 2px; }
  .modal-stat strong { font-size: 1.2rem; color: var(--navy); }
  .modal-stat span { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray); }

  .modal-remarks {
    font-size: 0.95rem;
    color: #4A4A5A;
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .modal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 0.82rem;
    color: var(--gray);
    padding-top: 20px;
    border-top: 1px solid var(--gray-light);
  }

  .modal-contact-btn {
    display: block;
    text-align: center;
    margin-top: 24px;
  }

  @media (max-width: 900px) {
    .results-grid, .loading-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .filter-bar { padding: 20px; }
    .results-grid, .loading-grid { grid-template-columns: 1fr; }
    .filter-location { min-width: 100%; }
    .modal-body { padding: 20px; }
    .modal-stats { gap: 20px; }
  }
</style>

<script>
// ─── CONFIG ──────────────────────────────────────────────────
// Replace these with your SimplyRETS credentials once you have them.
// Request them at https://simplyrets.com or via your CRR broker contact.
const API_USER = "simplyrets";
const API_PASS = "simplyrets";
const API_BASE = "https://api.simplyrets.com/properties";
const PER_PAGE = 9;
// ─────────────────────────────────────────────────────────────

const AUTH = "Basic " + btoa(`${API_USER}:${API_PASS}`);

// State
let currentPage = 1;
let totalCount  = 0;
let currentStatus = "Active";
let lastResults: any[] = [];

// DOM refs
const grid       = document.getElementById("results-grid")!;
const loadingEl  = document.getElementById("results-loading")!;
const emptyEl    = document.getElementById("results-empty")!;
const errorEl    = document.getElementById("results-error")!;
const metaEl     = document.getElementById("results-meta")!;
const countEl    = document.getElementById("results-count")!;
const paginEl    = document.getElementById("pagination")!;
const pageInfo   = document.getElementById("page-info")!;
const prevBtn    = document.getElementById("prev-page") as HTMLButtonElement;
const nextBtn    = document.getElementById("next-page") as HTMLButtonElement;
const sortSel    = document.getElementById("f-sort") as HTMLSelectElement;

// Filters
const fLocation = document.getElementById("f-location") as HTMLInputElement;
const fType     = document.getElementById("f-type") as HTMLSelectElement;
const fMinPrice = document.getElementById("f-minprice") as HTMLInputElement;
const fMaxPrice = document.getElementById("f-maxprice") as HTMLInputElement;
const fBeds     = document.getElementById("f-beds") as HTMLSelectElement;
const fBaths    = document.getElementById("f-baths") as HTMLSelectElement;

// Status toggle
document.querySelectorAll(".toggle-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".toggle-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
    currentStatus = (btn as HTMLElement).dataset.status || "Active";
  });
});

// Search button
document.getElementById("search-btn")?.addEventListener("click", () => {
  currentPage = 1;
  fetchListings();
});

// Enter key on location field
fLocation.addEventListener("keydown", (e) => {
  if (e.key === "Enter") { currentPage = 1; fetchListings(); }
});

// Sort change
sortSel?.addEventListener("change", () => sortAndRender(lastResults));

// Pagination
prevBtn?.addEventListener("click", () => { currentPage--; fetchListings(); });
nextBtn?.addEventListener("click", () => { currentPage++; fetchListings(); });

// Reset
document.getElementById("reset-btn")?.addEventListener("click", () => {
  fLocation.value = "";
  (document.getElementById("f-type") as HTMLSelectElement).value = "";
  fMinPrice.value = "";
  fMaxPrice.value = "";
  (document.getElementById("f-beds") as HTMLSelectElement).value = "";
  (document.getElementById("f-baths") as HTMLSelectElement).value = "";
  currentPage = 1;
  fetchListings();
});

// Retry
document.getElementById("retry-btn")?.addEventListener("click", fetchListings);

// Modal close
document.getElementById("modal-close")?.addEventListener("click", closeModal);
document.getElementById("modal-backdrop")?.addEventListener("click", closeModal);
document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

// ── Fetch ────────────────────────────────────────────────────
async function fetchListings() {
  showLoading();

  const params = new URLSearchParams();
  params.set("limit", String(PER_PAGE));
  params.set("offset", String((currentPage - 1) * PER_PAGE));
  params.set("status", currentStatus === "Active" ? "Active" : "Closed");
  params.set("count", "true");

  const loc = fLocation.value.trim();
  if (loc) params.set("q", loc);

  const type = (document.getElementById("f-type") as HTMLSelectElement).value;
  if (type) params.set("type", type);

  const minp = fMinPrice.value.trim();
  if (minp) params.set("minprice", minp);
  const maxp = fMaxPrice.value.trim();
  if (maxp) params.set("maxprice", maxp);

  const beds = (document.getElementById("f-beds") as HTMLSelectElement).value;
  if (beds) params.set("minbeds", beds);
  const baths = (document.getElementById("f-baths") as HTMLSelectElement).value;
  if (baths) params.set("minbaths", baths);

  try {
    const res = await fetch(`${API_BASE}?${params}`, {
      headers: { "Authorization": AUTH }
    });

    if (!res.ok) throw new Error(res.statusText);

    // SimplyRETS returns total count in X-Total-Count header
    const total = res.headers.get("X-Total-Count");
    totalCount = total ? parseInt(total) : 0;

    const data = await res.json();
    lastResults = data;
    sortAndRender(data);
  } catch (err) {
    showError();
  }
}

// ── Sort & Render ─────────────────────────────────────────────
function sortAndRender(data: any[]) {
  const sort = sortSel?.value || "listdate";
  const sorted = [...data].sort((a, b) => {
    if (sort === "price")     return a.listPrice - b.listPrice;
    if (sort === "priceDesc") return b.listPrice - a.listPrice;
    if (sort === "beds")      return (b.bedrooms || 0) - (a.bedrooms || 0);
    // newest: default from API
    return 0;
  });
  renderResults(sorted);
}

// ── Render results ────────────────────────────────────────────
function renderResults(data: any[]) {
  hideLoading();

  if (!data || data.length === 0) {
    showEmpty();
    return;
  }

  showResults();

  const totalPages = Math.ceil(totalCount / PER_PAGE) || 1;
  countEl.textContent = totalCount
    ? `${totalCount.toLocaleString()} propert${totalCount === 1 ? "y" : "ies"} found`
    : `${data.length} propert${data.length === 1 ? "y" : "ies"} found`;

  pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
  prevBtn.disabled = currentPage <= 1;
  nextBtn.disabled = currentPage >= totalPages;

  grid.innerHTML = data.map((p, i) => {
    const photo = p.photos?.[0];
    const status = p.status === "Active" ? "Active" : "Sold";
    const price = p.listPrice
      ? "$" + p.listPrice.toLocaleString()
      : "Contact for Price";
    const addr = p.address?.streetNumberText
      ? `${p.address.streetNumberText} ${p.address.streetName}`
      : p.address?.full || "Address not listed";
    const city = p.address
      ? `${p.address.city || ""}${p.address.city && p.address.state ? ", " : ""}${p.address.state || ""}${p.address.postalCode ? " " + p.address.postalCode : ""}`
      : "";
    const beds  = p.bedrooms  ?? "–";
    const baths = (p.bathsFull ?? 0) + (p.bathsHalf ? 0.5 : 0) || "–";
    const sqft  = p.area ? p.area.toLocaleString() : "–";
    const dom   = p.listDate
      ? Math.floor((Date.now() - new Date(p.listDate).getTime()) / 86400000)
      : null;

    return `
      <div class="prop-card" data-idx="${i}" tabindex="0" role="button" aria-label="View details for ${addr}">
        <div class="prop-img">
          ${photo
            ? `<img src="${photo}" alt="${addr}" loading="lazy" />`
            : `<div class="prop-img-placeholder">🏠</div>`
          }
          <span class="prop-status-badge${status === "Sold" ? " sold" : ""}">${status}</span>
          ${dom !== null ? `<span class="prop-dom">${dom === 0 ? "New" : dom + "d ago"}</span>` : ""}
        </div>
        <div class="prop-body">
          <p class="prop-price">${price}</p>
          <p class="prop-address">${addr}</p>
          <p class="prop-city">${city}</p>
          <div class="prop-details">
            <span><strong>${beds}</strong> bd</span>
            <span><strong>${baths}</strong> ba</span>
            <span><strong>${sqft}</strong> sqft</span>
          </div>
          <p class="prop-type">${p.type || ""} · MLS# ${p.listingId || p.mlsId || "–"}</p>
        </div>
      </div>`;
  }).join("");

  // Click handlers on cards
  grid.querySelectorAll(".prop-card").forEach((card) => {
    const handler = () => openModal(data[Number((card as HTMLElement).dataset.idx)]);
    card.addEventListener("click", handler);
    card.addEventListener("keydown", (e) => { if ((e as KeyboardEvent).key === "Enter") handler(); });
  });
}

// ── Modal ────────────────────────────────────────────────────
function openModal(p: any) {
  const modal   = document.getElementById("prop-modal")!;
  const content = document.getElementById("modal-content")!;

  const photo   = p.photos?.[0];
  const price   = p.listPrice ? "$" + p.listPrice.toLocaleString() : "Contact for Price";
  const addr    = p.address?.full || "Address not listed";
  const beds    = p.bedrooms ?? "–";
  const baths   = (p.bathsFull ?? 0) + (p.bathsHalf ? 0.5 : 0) || "–";
  const sqft    = p.area ? p.area.toLocaleString() : "–";
  const garage  = p.garageSpaces ? p.garageSpaces + " garage" : null;
  const year    = p.yearBuilt || null;
  const remarks = p.remarks || "";
  const status  = p.status === "Active" ? "Active Listing" : "Sold";

  content.innerHTML = `
    ${photo ? `<div class="modal-imgs"><img src="${photo}" alt="${addr}" /></div>` : ""}
    <div class="modal-body">
      <p style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--gold);margin-bottom:6px">${status}</p>
      <p class="modal-price">${price}</p>
      <p class="modal-address">${addr}</p>
      <div class="modal-stats">
        <div class="modal-stat"><strong>${beds}</strong><span>Bedrooms</span></div>
        <div class="modal-stat"><strong>${baths}</strong><span>Bathrooms</span></div>
        <div class="modal-stat"><strong>${sqft}</strong><span>Sq Ft</span></div>
        ${year ? `<div class="modal-stat"><strong>${year}</strong><span>Year Built</span></div>` : ""}
        ${garage ? `<div class="modal-stat"><strong>${garage}</strong><span>Parking</span></div>` : ""}
      </div>
      ${remarks ? `<p class="modal-remarks">${remarks}</p>` : ""}
      <div class="modal-meta">
        <span>Type: ${p.type || "–"}</span>
        <span>MLS#: ${p.listingId || p.mlsId || "–"}</span>
        ${p.address?.postalCode ? `<span>ZIP: ${p.address.postalCode}</span>` : ""}
      </div>
      <div class="modal-contact-btn">
        <a href="#contact" class="btn btn-primary" id="modal-contact-link">
          Contact Antoni About This Property
        </a>
      </div>
    </div>`;

  modal.style.display = "flex";
  document.body.style.overflow = "hidden";

  // clicking the contact button also closes modal
  document.getElementById("modal-contact-link")?.addEventListener("click", () => {
    closeModal();
  });
}

function closeModal() {
  const modal = document.getElementById("prop-modal")!;
  modal.style.display = "none";
  document.body.style.overflow = "";
}

// ── State helpers ─────────────────────────────────────────────
function showLoading() {
  grid.innerHTML = "";
  loadingEl.style.display = "grid";
  emptyEl.style.display = "none";
  errorEl.style.display = "none";
  metaEl.style.display = "none";
  paginEl.style.display = "none";
}

function hideLoading() {
  loadingEl.style.display = "none";
}

function showResults() {
  metaEl.style.display = "flex";
  paginEl.style.display = "flex";
  emptyEl.style.display = "none";
  errorEl.style.display = "none";
}

function showEmpty() {
  grid.innerHTML = "";
  emptyEl.style.display = "block";
  metaEl.style.display = "none";
  paginEl.style.display = "none";
}

function showError() {
  hideLoading();
  grid.innerHTML = "";
  errorEl.style.display = "block";
  metaEl.style.display = "none";
  paginEl.style.display = "none";
}

// Auto-load on page open
fetchListings();
</script>

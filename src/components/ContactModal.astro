---
---

<div id="contact-modal" class="modal-backdrop" aria-hidden="true">
  <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <button class="modal-close" id="modal-close" aria-label="Close">✕</button>

    <div class="modal-header">
      <p class="section-label">Get In Touch</p>
      <h2 id="modal-title">Ready to Make Your Move?</h2>
      <p class="modal-sub">We'd love to hear from you. Fill out the form and we'll be in touch shortly.</p>
    </div>

    <form action="#" method="post" class="modal-form">
      <div class="form-row">
        <div class="form-group">
          <label for="m-name">Full Name *</label>
          <input type="text" id="m-name" name="name" required placeholder="Your full name" />
        </div>
        <div class="form-group">
          <label for="m-phone">Phone Number</label>
          <input type="tel" id="m-phone" name="phone" placeholder="(555) 555-5555" />
        </div>
      </div>

      <div class="form-group">
        <label for="m-email">Email Address *</label>
        <input type="email" id="m-email" name="email" required placeholder="your@email.com" />
      </div>

      <div class="form-group">
        <label for="m-interest">I'm Interested In...</label>
        <select id="m-interest" name="interest">
          <option value="">Select one...</option>
          <option value="buying">Buying a Home</option>
          <option value="selling">Selling a Home</option>
          <option value="investing">Real Estate Investment</option>
          <option value="first-time">First-Time Homebuyer Guidance</option>
          <option value="other">Other / General Inquiry</option>
        </select>
      </div>

      <div class="form-group">
        <label for="m-message">Message</label>
        <textarea id="m-message" name="message" rows="4" placeholder="Tell us about your real estate needs..."></textarea>
      </div>

      <button type="submit" class="btn btn-primary modal-submit">
        Send Message
      </button>
    </form>
  </div>
</div>

<style>
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(18, 40, 73, 0.6);
    backdrop-filter: blur(6px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .modal-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }

  .modal-panel {
    background: var(--white);
    border-radius: 24px;
    padding: 48px 44px 44px;
    max-width: 560px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    transform: translateY(32px) scale(0.97);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.35s ease;
    opacity: 0;
    box-shadow: 0 32px 80px rgba(18, 40, 73, 0.22);
  }

  .modal-backdrop.open .modal-panel {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .modal-close {
    position: absolute;
    top: 18px;
    right: 20px;
    background: var(--gray-light);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    font-size: 0.85rem;
    color: var(--navy);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, color 0.2s;
  }

  .modal-close:hover {
    background: var(--navy);
    color: var(--white);
  }

  .modal-header {
    margin-bottom: 28px;
  }

  .modal-header h2 {
    font-size: 1.9rem;
    color: var(--navy);
    margin-bottom: 8px;
  }

  .modal-sub {
    font-size: 0.93rem;
    color: var(--gray);
    line-height: 1.6;
  }

  .modal-form .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .modal-form .form-group {
    margin-bottom: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modal-form label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: 0.03em;
  }

  .modal-form input,
  .modal-form select,
  .modal-form textarea {
    padding: 12px 16px;
    border: 1.5px solid #DDD;
    border-radius: 10px;
    font-size: 0.93rem;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    resize: vertical;
  }

  .modal-form input:focus,
  .modal-form select:focus,
  .modal-form textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.18);
  }

  .modal-submit {
    width: 100%;
    justify-content: center;
    margin-top: 4px;
  }

  @media (max-width: 560px) {
    .modal-panel { padding: 36px 24px 32px; }
    .modal-form .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const backdrop = document.getElementById('contact-modal');
  const closeBtn = document.getElementById('modal-close');

  function openModal() {
    backdrop?.classList.add('open');
    backdrop?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    backdrop?.classList.remove('open');
    backdrop?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Close on backdrop click
  backdrop?.addEventListener('click', (e) => {
    if (e.target === backdrop) closeModal();
  });

  // Close on X button
  closeBtn?.addEventListener('click', closeModal);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Wire up all buttons with data-modal="contact"
  document.querySelectorAll('[data-modal="contact"]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });
</script>

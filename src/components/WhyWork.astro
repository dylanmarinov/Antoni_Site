---
const features = [
  { num: "01", title: "First-Time Homebuyer Friendly", description: "I walk you through every step from pre-approval to closing day — you'll always feel informed and in control." },
  { num: "02", title: "Investor-Friendly", description: "From rental income properties to fix-and-flip opportunities, I help you find deals that maximize your return." },
  { num: "03", title: "Tampa Bay Market Expert", description: "21+ years of boots-on-the-ground experience across every neighborhood in the greater Tampa Bay Area." },
  { num: "04", title: "No-Pressure Approach", description: "I work at your pace, on your terms. Zero pressure, zero judgment — always." },
  { num: "05", title: "Detail-Oriented", description: "I thoroughly inspect every home and am always upfront about issues — your long-term happiness matters." },
  { num: "06", title: "Proven Track Record", description: "Affiliated with Charles Rutenberg Realty, Florida's top independent brokerage, with decades of results." },
];
---
<section id="why-work">
  <div class="container">
    <div class="why-header reveal">
      <p class="section-label">Why Work With Me</p>
      <h2 class="section-title">Six Reasons Clients Choose Antoni</h2>
      <span class="line-draw"></span>
    </div>
    <div class="features-grid stagger">
      {features.map(f => (
        <div class="feature-row">
          <span class="feature-num">{f.num}</span>
          <div class="feature-body">
            <h3>{f.title}</h3>
            <p>{f.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #why-work { background: var(--off-white); }
  .why-header { margin-bottom: 56px; }
  .features-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-top: 1px solid #E5E7EB; border-left: 1px solid #E5E7EB; }
  .feature-row {
    display: flex; gap: 24px; padding: 36px 32px;
    border-right: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;
    background: var(--white);
    transition: background var(--transition);
  }
  .feature-row:hover { background: #EFF6FF; }
  .feature-num { font-size: 2rem; font-weight: 800; color: #DBEAFE; flex-shrink: 0; line-height: 1; width: 48px; }
  .feature-row:hover .feature-num { color: var(--gold); }
  .feature-body h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
  .feature-body p { font-size: 0.88rem; color: var(--gray); line-height: 1.65; }
  @media (max-width: 700px) { .features-grid { grid-template-columns: 1fr; } }
</style>

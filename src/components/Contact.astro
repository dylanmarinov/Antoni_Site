---
const agents = [
  {
    name: "Antoni D. Marinov",
    phone: "727-458-4192",
    email: "Makakbe@hotmail.com",
    license: "123456",
    zillowProfile: "https://www.zillow.com/profile/Antoni%20D%20Marinov",
  },
  {
    name: "Dylan Marinov",
    phone: "727-776-8787",
    email: "dylanmarinovrealtor@gmail.com",
    license: "",
    zillowProfile: "https://www.zillow.com/profile/dylanmarinovrealtor",
  },
];
const brokerage = "Charles Rutenberg Realty";
const brokerageUrl = "https://gocrr.com/";
---

<section id="contact">
  <div class="container">
    <div class="contact-grid">

      <div class="contact-info reveal from-left">
        <p class="section-label">Get In Touch</p>
        <h2 class="section-title">Ready to Make<br/>Your Move?</h2>
        <p class="contact-intro">
          Whether you're buying your first home, selling, or building an investment portfolio
          — we'd love to hear from you. Reach out to either of us and let's talk about your goals.
        </p>

        <div class="agents-contact">
          {agents.map(agent => (
            <div class="agent-contact-card">
              <p class="agent-contact-name">{agent.name}</p>
              <ul class="contact-details">
                <li>
                  <span class="contact-icon">📞</span>
                  <div>
                    <span class="contact-detail-label">Phone</span>
                    <a href={`tel:${agent.phone.replace(/\D/g, "")}`} class="contact-detail-value">
                      {agent.phone}
                    </a>
                  </div>
                </li>
                <li>
                  <span class="contact-icon">✉️</span>
                  <div>
                    <span class="contact-detail-label">Email</span>
                    <a href={`mailto:${agent.email}`} class="contact-detail-value">
                      {agent.email}
                    </a>
                  </div>
                </li>
                {agent.license && (
                  <li>
                    <span class="contact-icon">🪪</span>
                    <div>
                      <span class="contact-detail-label">FL License</span>
                      <span class="contact-detail-value">{agent.license}</span>
                    </div>
                  </li>
                )}
              </ul>
              <a href={agent.zillowProfile} target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="margin-top:12px;">
                View Zillow Profile
              </a>
            </div>
          ))}
        </div>

        <div class="brokerage-row">
          <span class="contact-icon">🏢</span>
          <div>
            <span class="contact-detail-label">Brokerage</span>
            <a href={brokerageUrl} target="_blank" rel="noopener noreferrer" class="contact-detail-value">
              {brokerage}
            </a>
          </div>
        </div>
      </div>

      <div class="contact-form-wrap reveal from-right">
        <!-- TODO: Replace action="#" with your Formspree URL.
             Free at formspree.io — create an account, make a form,
             and paste the URL they give you as the action value below. -->
        <form action="#" method="post" class="contact-form">
          <h3>Send Me a Message</h3>

          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" required placeholder="Your full name" />
            </div>
            <div class="form-group">
              <label for="phone-input">Phone Number</label>
              <input type="tel" id="phone-input" name="phone" placeholder="(555) 555-5555" />
            </div>
          </div>

          <div class="form-group">
            <label for="email-input">Email Address *</label>
            <input type="email" id="email-input" name="email" required placeholder="your@email.com" />
          </div>

          <div class="form-group">
            <label for="interest">I'm Interested In...</label>
            <select id="interest" name="interest">
              <option value="">Select one...</option>
              <option value="buying">Buying a Home</option>
              <option value="selling">Selling a Home</option>
              <option value="investing">Real Estate Investment</option>
              <option value="first-time">First-Time Homebuyer Guidance</option>
              <option value="other">Other / General Inquiry</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell me about your real estate needs..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            Send Message
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  #contact {
    background: var(--white);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-intro {
    color: #5A5A6A;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .agents-contact {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 24px;
  }

  .agent-contact-card {
    background: var(--off-white);
    border-radius: 14px;
    padding: 20px 24px 16px;
  }

  .agent-contact-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 14px;
  }

  .brokerage-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 4px;
  }

  .contact-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 32px;
  }

  .contact-details li {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .contact-icon {
    font-size: 1.3rem;
    width: 48px; height: 48px;
    background: var(--off-white);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-detail-label {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
    margin-bottom: 2px;
  }

  .contact-detail-value {
    display: block;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--navy);
    transition: color 0.2s;
  }

  a.contact-detail-value:hover { color: var(--gold); }

  /* Form */
  .contact-form-wrap {
    transition-delay: 0.15s;
  }

  .contact-form {
    background: var(--off-white);
    border-radius: 20px;
    padding: 40px;
    box-shadow: var(--shadow);
  }

  .contact-form h3 {
    font-size: 1.4rem;
    color: var(--navy);
    margin-bottom: 28px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    margin-bottom: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: 0.03em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 12px 16px;
    border: 1.5px solid #DDD;
    border-radius: 10px;
    font-size: 0.93rem;
    font-family: inherit;
    color: var(--text);
    background: var(--white);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.2);
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 48px; }
    .form-row { grid-template-columns: 1fr; }
    .contact-form { padding: 28px 24px; }
  }
</style>

---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="about">
  <div class="container">

    <div class="about-header reveal">
      <p class="section-label">Meet the Team</p>
      <h2 class="section-title">The Marinov Team</h2>
      <span class="line-draw"></span>
      <p class="section-sub">
        Two generations of real estate expertise serving the greater Tampa Bay Area.
        We combine decades of market experience with fresh energy and a shared commitment
        to putting our clients first — every time.
      </p>
    </div>

    <div class="agents-grid">

      <!-- Antoni -->
      <div class="agent-card reveal from-left">
        <div class="agent-img-wrap">
          <div class="agent-img-frame">
            <img src={`${base}/headshot.png`} alt="Antoni Marinov, REALTOR®" />
          </div>
          <div class="agent-badge">
            <span class="badge-num">25+</span>
            <span class="badge-text">Years in<br/>Tampa Bay</span>
          </div>
        </div>
        <div class="agent-info">
          <h3 class="agent-name">Antoni Marinov</h3>
          <p class="agent-title">REALTOR® | Charles Rutenberg Realty</p>
          <span class="line-draw agent-line"></span>
          <p>
            For over 25 years, Antoni has been helping buyers, sellers, and investors navigate
            the greater Tampa Bay real estate market with confidence. Affiliated with
            <a href="https://gocrr.com/" target="_blank" rel="noopener noreferrer" class="text-link">Charles Rutenberg Realty</a>
            — one of Florida's most respected independent brokerages — he has built a career on
            honest advice, meticulous attention to detail<span class="bio-extra">, and an unwavering commitment to his
            clients' best interests. He specializes in working with first-time homebuyers and
            real estate investors alike, bringing deep neighborhood knowledge and sharp
            negotiating skills to every transaction</span>.
          </p>
          <ul class="agent-creds stagger">
            <li><span class="cred-icon">✦</span> 25+ Years at Charles Rutenberg Realty</li>
            <li><span class="cred-icon">✦</span> Licensed Florida REALTOR®</li>
            <li><span class="cred-icon">✦</span> Investment Property Specialist</li>
            <li><span class="cred-icon">✦</span> First-Time Homebuyer Specialist</li>
          </ul>
          <div class="agent-actions">
            <a href="tel:7274584192" class="btn btn-primary">📞 727-458-4192</a>
            <a href="https://www.zillow.com/profile/Antoni%20D%20Marinov" target="_blank" rel="noopener noreferrer" class="btn btn-navy">Zillow Profile</a>
          </div>
        </div>
      </div>

      <!-- Dylan -->
      <div class="agent-card reveal from-right">
        <div class="agent-img-wrap">
          <div class="agent-img-frame">
            <img src={`${base}/dylan-headshot.png`} alt="Dylan Marinov, REALTOR®" />
          </div>
          <div class="agent-badge agent-badge-new">
            <span class="badge-num">New</span>
            <span class="badge-text">Generation<br/>REALTOR®</span>
          </div>
        </div>
        <div class="agent-info">
          <h3 class="agent-name">Dylan Marinov</h3>
          <p class="agent-title">REALTOR® | Charles Rutenberg Realty</p>
          <span class="line-draw agent-line"></span>
          <p>
            As a licensed Florida REALTOR® with Charles Rutenberg Realty, Dylan brings fresh
            energy and a client-first mindset to every transaction. Partnering alongside Antoni,
            he combines modern market insight with the deep Tampa Bay expertise the Marinov Team
            is known for<span class="bio-extra">. Dylan is passionate about helping first-time homebuyers navigate the
            process with confidence, and works closely with investors to identify the right
            opportunities across the Tampa Bay market. Whether you're buying, selling, or
            investing, Dylan is here to guide you every step of the way — with transparency,
            dedication, and zero pressure</span>.
          </p>
          <ul class="agent-creds stagger">
            <li><span class="cred-icon">✦</span> Licensed Florida REALTOR®</li>
            <li><span class="cred-icon">✦</span> Charles Rutenberg Realty</li>
            <li><span class="cred-icon">✦</span> First-Time Homebuyer Specialist</li>
            <li><span class="cred-icon">✦</span> Greater Tampa Bay Area Expert</li>
          </ul>
          <div class="agent-actions">
            <a href="tel:7277768787" class="btn btn-primary">📞 727-776-8787</a>
            <a href="https://www.zillow.com/profile/dylanmarinovrealtor" target="_blank" rel="noopener noreferrer" class="btn btn-navy">Zillow Profile</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #about {
    background: var(--off-white);
  }

  .about-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .about-header .line-draw {
    margin: 0 auto 20px;
  }

  .about-header .section-sub {
    margin: 0 auto;
  }

  .agents-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .agent-card {
    background: var(--white);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: box-shadow var(--transition);
  }

  .agent-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .agent-img-wrap {
    position: relative;
  }

  .agent-img-frame {
    overflow: hidden;
    aspect-ratio: 2/3;
  }

  .agent-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 8%;
    transition: transform 0.6s ease;
  }

  .agent-card:hover .agent-img-frame img {
    transform: scale(1.03);
  }

  .agent-badge {
    position: absolute;
    bottom: -20px;
    right: 28px;
    background: var(--gold);
    color: var(--navy-dark);
    border-radius: 12px;
    padding: 14px 18px;
    text-align: center;
    box-shadow: var(--shadow);
    z-index: 1;
  }

  .agent-badge-new {
    background: var(--navy);
    color: var(--white);
  }

  .badge-num {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
  }

  .badge-text {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.4;
  }

  .agent-info {
    padding: 40px 28px 28px;
  }

  .agent-name {
    font-size: 1.6rem;
    color: var(--navy);
    margin-bottom: 4px;
  }

  .agent-title {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .agent-line {
    margin-bottom: 18px;
  }

  .agent-info p {
    color: #4A4A5A;
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 4px;
  }

  .text-link {
    color: var(--gold);
    font-weight: 600;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.2s;
  }
  .text-link:hover { opacity: 0.75; }

  .agent-creds {
    list-style: none;
    margin: 20px 0 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .agent-creds li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
  }

  .cred-icon {
    color: var(--gold);
    font-size: 0.65rem;
    flex-shrink: 0;
  }

  .agent-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .agents-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 600px) {
    .about-header { margin-bottom: 36px; }
    .bio-extra { display: none; }
    .agent-creds li:nth-child(n+4) { display: none; }
    .agent-img-frame { aspect-ratio: 4/3; }
  }
</style>

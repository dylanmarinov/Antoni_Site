---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="about">
  <div class="container about-grid">

    <div class="about-image-wrap reveal from-left">
      <div class="about-img-frame">
        <img
          src={`${base}/headshot.png`}
          alt="Antoni D. Marinov, REALTOR®"
        />
      </div>
      <div class="about-badge">
        <span class="badge-num">21+</span>
        <span class="badge-text">Years in<br/>Tampa Bay</span>
      </div>
    </div>

    <div class="about-text reveal from-right">
      <p class="section-label">About Antoni</p>
      <h2 class="section-title">Your Florida Real Estate Expert</h2>
      <span class="line-draw"></span>

      <p>
        For over two decades, I have been helping buyers, sellers, and investors navigate the
        greater Tampa Bay real estate market with confidence. As a REALTOR® with
        <a href="https://gocrr.com/" target="_blank" rel="noopener noreferrer" class="text-link">Charles Rutenberg Realty</a>
        — one of Florida's most respected independent brokerages — I have built a career on
        honest advice, meticulous attention to detail, and an unwavering commitment to my clients'
        best interests.
      </p>

      <p>
        I specialize in working with <strong>first-time homebuyers</strong> and
        <strong>real estate investors</strong> alike. Whether you're stepping onto the property
        ladder for the first time or growing a portfolio across the Tampa Bay Area, I bring the
        market knowledge and hands-on experience to help you make smart decisions at every step.
      </p>

      <p>
        I take the time to thoroughly inspect every home we tour and am always upfront about
        anything that could be a concern — because your long-term satisfaction matters more to
        me than a quick sale. No pressure, ever.
      </p>

      <ul class="about-creds stagger">
        <li>
          <span class="cred-icon">→</span>
          21+ Years at Charles Rutenberg Realty
        </li>
        <li>
          <span class="cred-icon">→</span>
          Licensed Florida REALTOR®
        </li>
        <li>
          <span class="cred-icon">→</span>
          Investment Property Specialist
        </li>
        <li>
          <span class="cred-icon">→</span>
          First-Time Homebuyer Specialist
        </li>
        <li>
          <span class="cred-icon">→</span>
          Greater Tampa Bay Area Market Expert
        </li>
      </ul>

      <div class="about-actions">
        <a href="#contact" class="btn btn-primary">Work With Me</a>
        <a href="https://gocrr.com/" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          Charles Rutenberg Realty
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  #about {
    background: var(--off-white);
  }

  #about .section-title { color: var(--text); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .about-image-wrap {
    position: relative;
    transition-delay: 0s;
  }

  .about-img-frame {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .about-img-frame img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.6s ease;
  }

  .about-img-frame:hover img { transform: scale(1.03); }

  .about-badge {
    position: absolute;
    bottom: 24px;
    right: 32px;
    background: var(--teal);
    color: var(--dark);
    border-radius: 8px;
    padding: 20px 24px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,212,170,0.3);
  }

  .badge-num {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
  }

  .badge-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.5;
  }

  .about-text {
    transition-delay: 0.15s;
  }

  .about-text .section-label { color: var(--teal); }
  .about-text .section-title { color: var(--text); }

  .about-text p {
    color: #555;
    margin-bottom: 18px;
    font-size: 0.97rem;
    line-height: 1.85;
  }

  .about-text strong { color: var(--dark); font-weight: 600; }

  .text-link {
    color: var(--teal-dim);
    font-weight: 600;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.2s;
  }
  .text-link:hover { opacity: 0.7; }

  .about-creds {
    list-style: none;
    margin: 28px 0 36px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .about-creds li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
  }

  .cred-icon {
    color: var(--teal-dim);
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .about-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-badge { right: 32px; bottom: 20px; }
  }
</style>

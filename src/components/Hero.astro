---
---
<section id="home" class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow reveal">Tampa Bay Area · REALTOR®</p>
    <h1 class="reveal">The Smarter Way to Buy, Sell &amp; Invest in Florida</h1>
    <p class="hero-sub reveal">21+ years of market expertise. Zero pressure. 100% commitment to finding you the right home — not just any home.</p>
    <div class="hero-ctas reveal">
      <a href="#search" class="btn btn-primary">Search Properties</a>
      <a href="#contact" class="btn btn-ghost">Contact Antoni</a>
    </div>
    <div class="hero-trust stagger">
      <div class="trust-item"><span class="trust-num">21+</span><span class="trust-lbl">Years Experience</span></div>
      <div class="trust-divider"></div>
      <div class="trust-item"><span class="trust-num">500+</span><span class="trust-lbl">Clients Served</span></div>
      <div class="trust-divider"></div>
      <div class="trust-item"><span class="trust-num">5★</span><span class="trust-lbl">Zillow Rating</span></div>
    </div>
  </div>
  <div class="hero-right reveal from-right">
    <div class="hero-img-stack">
      <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=900&q=85&auto=format&fit=crop" alt="Luxury Tampa Bay home" class="hero-img-main" />
      <div class="hero-img-badge">
        <span>Charles Rutenberg Realty</span>
        <strong>Tampa Bay's #1 Independent Brokerage</strong>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 0;
    overflow: hidden;
  }
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 64px 80px;
    background: var(--off-white);
  }
  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    transition-delay: 0.1s;
  }
  h1 {
    font-size: clamp(2.2rem, 3.5vw, 3.4rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--navy);
    margin-bottom: 20px;
    transition-delay: 0.2s;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--gray);
    max-width: 460px;
    margin-bottom: 36px;
    transition-delay: 0.3s;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    margin-bottom: 56px;
    transition-delay: 0.4s;
    flex-wrap: wrap;
  }
  .btn-ghost { color: var(--navy); border-color: #D1D5DB; }
  .btn-ghost:hover { border-color: var(--navy); box-shadow: none; }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid #E5E7EB;
  }
  .trust-item { display: flex; flex-direction: column; gap: 2px; }
  .trust-num { font-size: 1.6rem; font-weight: 800; color: var(--navy); line-height: 1; }
  .trust-lbl { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray); }
  .trust-divider { width: 1px; height: 36px; background: #E5E7EB; }

  .hero-right {
    position: relative;
    overflow: hidden;
    transition-delay: 0.2s;
  }
  .hero-img-stack { width: 100%; height: 100%; position: relative; }
  .hero-img-main { width: 100%; height: 100%; object-fit: cover; }
  .hero-img-badge {
    position: absolute;
    bottom: 32px; left: 32px; right: 32px;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-radius: 8px;
    padding: 16px 20px;
    box-shadow: var(--shadow-lg);
  }
  .hero-img-badge span { display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); font-weight: 700; margin-bottom: 4px; }
  .hero-img-badge strong { display: block; font-size: 0.9rem; color: var(--navy); }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-left { padding: 120px 32px 60px; }
    .hero-right { height: 400px; }
  }
</style>

---
---

<section id="home" class="hero">
  <div class="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1800&q=85&auto=format&fit=crop"
      alt="Luxury home in Tampa Bay, Florida"
      class="hero-img"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <p class="hero-eyebrow reveal">Tampa Bay Area REALTOR®</p>
    <h1 class="hero-title reveal">
      Your Trusted Guide<br />
      to <em>Florida Real Estate</em>
    </h1>
    <div class="hero-divider reveal">
      <span class="divider-line"></span>
      <span class="divider-diamond">◆</span>
      <span class="divider-line"></span>
    </div>
    <p class="hero-sub reveal">
      21+ Years of Experience &nbsp;·&nbsp; Investor-Friendly &nbsp;·&nbsp; First-Time Homebuyer Specialist
    </p>
    <div class="hero-actions reveal">
      <a href="#search" class="btn btn-primary">Search Properties</a>
      <a href="#contact" class="btn btn-outline">Get In Touch</a>
    </div>

    <div class="hero-stats stagger">
      <div class="stat">
        <span class="stat-num" data-count="21" data-suffix="+">21+</span>
        <span class="stat-label">Years Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num" data-count="500" data-suffix="+">500+</span>
        <span class="stat-label">Clients Served</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">5★</span>
        <span class="stat-label">Zillow Rating</span>
      </div>
    </div>
  </div>

  <a href="#about" class="scroll-hint" aria-label="Scroll down">
    <span class="scroll-arrow"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 24px 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.05);
    animation: zoomOut 10s ease forwards;
  }

  @keyframes zoomOut {
    from { transform: scale(1.05); }
    to   { transform: scale(1.0); }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      175deg,
      rgba(26,15,10,0.88) 0%,
      rgba(44,24,16,0.72) 55%,
      rgba(26,15,10,0.85) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 820px;
  }

  .hero-eyebrow {
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    transition-delay: 0.1s;
  }

  .hero-title {
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 600;
    color: var(--white);
    margin-bottom: 28px;
    line-height: 1.1;
    transition-delay: 0.2s;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
    transition-delay: 0.3s;
  }

  .divider-line {
    display: block;
    width: 60px;
    height: 1px;
    background: rgba(196,98,45,0.5);
  }

  .divider-diamond {
    color: var(--gold);
    font-size: 0.5rem;
    opacity: 0.7;
  }

  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    margin-bottom: 44px;
    letter-spacing: 0.03em;
    transition-delay: 0.35s;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 72px;
    transition-delay: 0.45s;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 36px;
    background: rgba(26,15,10,0.55);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(196,98,45,0.25);
    border-radius: 0;
    padding: 28px 48px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 600;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-family: 'Lato', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
  }

  .stat-divider {
    width: 1px;
    height: 44px;
    background: rgba(196,98,45,0.3);
  }

  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    animation: bounce 2.2s ease-in-out infinite;
  }

  .scroll-arrow {
    display: block;
    width: 18px; height: 18px;
    border-right: 1px solid rgba(255,255,255,0.5);
    border-bottom: 1px solid rgba(255,255,255,0.5);
    transform: rotate(45deg);
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(10px); }
  }

  @media (max-width: 600px) {
    .stat-divider { display: none; }
    .hero-stats { gap: 24px; padding: 24px 28px; }
  }
</style>

---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const listings = [
  {
    status: "Active",
    address: "531 Isleworth Close",
    city: "Tarpon Springs", state: "FL", zip: "34688",
    price: "Contact for Price",
    beds: 5, baths: 4, sqft: 4570,
    description: "Luxury Mediterranean-style home in the prestigious gated Wentworth Golf Course community. 5 bed / 4 bath with 4,570 sq ft of refined living space.",
    link: "https://us-east.prospects.com/prospects/outside/inscription.do?tok=Z5kbYbSXOUncnHYEUW+cBmj6w2ACj/MvVx4j0hd465E2SNuje1wQIdIXeOCQNFvbriJRWm+JBWfomTJUy/cvHVp6jght5507B462YwhIcIkFd+rDZkbDo3ECSnyHVjX1gj5U3Kt7BVQu0Rd44JA0SNq+bQgbI5wXbeedJ1LQvnAISGCDVjX1gjtb0fd6D1pviQ9U+5ExU9P3LFcRKtJZN/WCPl7vuHAHT3+wCnbskCMHjPwoWBQh0hd44ZolB48=",
    image: `${base}/listing-531-isleworth.jpg`,
  },
  {
    status: "Sold",
    address: "5346 Neil Dr",
    city: "Saint Petersburg", state: "FL", zip: "33714",
    price: "Sold",
    beds: 3, baths: 2.5, sqft: 1700,
    description: "Townhouse in a gated community featuring an open floor plan, updated kitchen, and an attached 2-car garage.",
    link: "https://www.zillow.com/profile/Antoni%20D%20Marinov",
    image: `${base}/listing-neil-dr.webp`,
  },
  {
    status: "Sold",
    address: "7032 Pelican Island Dr",
    city: "Tampa", state: "FL", zip: "33634",
    price: "Sold",
    beds: 3, baths: 2, sqft: 2342,
    description: "Renovated single-family home in a gated golf course community featuring an open floor plan, modern kitchen, and private pool.",
    link: "https://www.zillow.com/profile/Antoni%20D%20Marinov",
    image: `${base}/listing-pelican-island.webp`,
  },
];
---
<section id="listings">
  <div class="container">
    <div class="listings-header reveal">
      <p class="section-label">Featured Listings</p>
      <h2 class="section-title">Properties I'm Proud to Represent</h2>
      <span class="line-draw"></span>
    </div>
    <div class="listings-list stagger">
      {listings.map(l => (
        <a class="listing-row" href={l.link} target="_blank" rel="noopener noreferrer">
          <div class="listing-img">
            <img src={l.image} alt={l.address} />
            <span class={`listing-badge ${l.status === 'Sold' ? 'badge-sold' : 'badge-active'}`}>{l.status}</span>
          </div>
          <div class="listing-info">
            <p class="listing-price">{l.price}</p>
            <h3 class="listing-address">{l.address}</h3>
            <p class="listing-city">{l.city}, {l.state} {l.zip}</p>
            <div class="listing-details">
              <span><strong>{l.beds}</strong> bd</span>
              <span><strong>{l.baths}</strong> ba</span>
              <span><strong>{l.sqft.toLocaleString()}</strong> sqft</span>
            </div>
            <p class="listing-desc">{l.description}</p>
          </div>
          <div class="listing-arrow">→</div>
        </a>
      ))}
    </div>
    <div class="listings-cta reveal">
      <a href="https://www.zillow.com/profile/Antoni%20D%20Marinov" target="_blank" rel="noopener noreferrer" class="btn btn-navy">View All Listings on Zillow</a>
    </div>
  </div>
</section>

<style>
  #listings { background: var(--white); }
  .listings-header { margin-bottom: 48px; }
  .listings-list { display: flex; flex-direction: column; gap: 2px; margin-bottom: 48px; border: 1px solid #E5E7EB; border-radius: 8px; overflow: hidden; }
  .listing-row {
    display: grid; grid-template-columns: 280px 1fr 48px;
    align-items: center; gap: 0;
    background: var(--white);
    border-bottom: 1px solid #E5E7EB;
    transition: background var(--transition);
    color: inherit;
  }
  .listing-row:last-child { border-bottom: none; }
  .listing-row:hover { background: var(--off-white); }
  .listing-img { position: relative; height: 180px; overflow: hidden; }
  .listing-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .listing-row:hover .listing-img img { transform: scale(1.04); }
  .listing-badge { position: absolute; top: 12px; left: 12px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 4px; }
  .badge-active { background: var(--gold); color: var(--white); }
  .badge-sold { background: var(--navy); color: var(--white); }
  .listing-info { padding: 24px 32px; }
  .listing-price { font-size: 1.3rem; font-weight: 800; color: var(--navy); margin-bottom: 2px; }
  .listing-address { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 2px; }
  .listing-city { font-size: 0.82rem; color: var(--gray); margin-bottom: 10px; }
  .listing-details { display: flex; gap: 16px; font-size: 0.82rem; color: var(--gray); margin-bottom: 8px; }
  .listing-details strong { color: var(--text); }
  .listing-desc { font-size: 0.85rem; color: var(--gray); line-height: 1.6; }
  .listing-arrow { font-size: 1.2rem; color: var(--gray); text-align: center; transition: color var(--transition), transform var(--transition); }
  .listing-row:hover .listing-arrow { color: var(--gold); transform: translateX(4px); }
  .listings-cta { text-align: center; }
  @media (max-width: 700px) {
    .listing-row { grid-template-columns: 1fr; }
    .listing-img { height: 220px; }
    .listing-arrow { display: none; }
  }
</style>
